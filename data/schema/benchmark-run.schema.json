{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:zalastack:agent-harnesses:schema:benchmark-run:v0.1.0-draft",
  "title": "BenchmarkRun",
  "type": "object",
  "required": ["run_id", "created_at", "design", "tasks"],
  "properties": {
    "run_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "design": {"type": "string", "enum": ["paired-randomized"]},
    "runner": {"type": "string", "enum": ["hermes", "codex-native", "paired"]},
    "environment": {"type": "object"},
    "tasks": {
      "type": "array",
      "items": {"$ref": "./task-result.schema.json"}
    }
  }
}
